# Job Board API Configuration
# Copy this file to .env and add your actual API keys

# ============================================================================
# INDEED API (Publisher Program)
# ============================================================================
# Apply at: https://www.indeed.com/publisher
# Documentation: https://opensource.indeedeng.io/api-documentation/
INDEED_PUBLISHER_ID=your_publisher_id_here
INDEED_API_TOKEN=your_api_token_here

# ============================================================================
# ADZUNA API (Free tier available - 1000 calls/month)
# ============================================================================
# Apply at: https://developer.adzuna.com/
# Sign up is instant and free!
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# ============================================================================
# THE MUSE API (Free - no registration required for basic use)
# ============================================================================
# Documentation: https://www.themuse.com/developers/api/v2
# No key needed for basic searches, but recommended to register
THE_MUSE_API_KEY=optional_api_key_here

# ============================================================================
# USAJOBS API (U.S. Government Jobs - Free)
# ============================================================================
# Apply at: https://developer.usajobs.gov/
USAJOBS_API_KEY=your_api_key_here
USAJOBS_USER_AGENT=your_email@example.com

# ============================================================================
# GITHUB JOBS API (Free - No key required)
# ============================================================================
# Documentation: https://jobs.github.com/api
# No authentication needed

# ============================================================================
# REMOTIVE API (Remote jobs - Free)
# ============================================================================
# Documentation: https://remotive.com/api-documentation
# No authentication needed for basic use

# ============================================================================
# LINKEDIN API (OAuth required - Complex setup)
# ============================================================================
# Apply at: https://www.linkedin.com/developers/
# Requires company verification and OAuth flow
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# ============================================================================
# ZIPRECRUITER API (Partner Program)
# ============================================================================
# Apply at: https://www.ziprecruiter.com/zr-api
# Requires partner application approval
ZIPRECRUITER_API_KEY=your_api_key_here

# ============================================================================
# GLASSDOOR API (Restricted - Hard to get)
# ============================================================================
# Apply at: https://www.glassdoor.com/developer/index.htm
# Note: Glassdoor has largely restricted API access
GLASSDOOR_PARTNER_ID=your_partner_id_here
GLASSDOOR_API_KEY=your_api_key_here

# ============================================================================
# JOOBLE API (Free tier available)
# ============================================================================
# Apply at: https://jooble.org/api/about
JOOBLE_API_KEY=your_api_key_here

# ============================================================================
# REED API (UK-focused - Free)
# ============================================================================
# Apply at: https://www.reed.co.uk/developers
REED_API_KEY=your_api_key_here

# ============================================================================
# CAREERJET API (Free)
# ============================================================================
# Apply at: https://www.careerjet.com/partners/api/
CAREERJET_AFFILIATE_ID=your_affiliate_id_here

# ============================================================================
# Application Settings
# ============================================================================
# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Cache settings (in minutes)
CACHE_DURATION_MINUTES=15

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# Default search parameters
DEFAULT_MAX_RESULTS=50
DEFAULT_LOCATION=Remote

# Logging
LOG_LEVEL=info
LOG_API_REQUESTS=true
